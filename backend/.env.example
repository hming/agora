ANTHROPIC_API_KEY=your-key-here
REDIS_URL=redis://localhost:6379

# LLM provider: claude (default) or mock (no API key needed, for local testing)
LLM_PROVIDER=claude

# Interval between Epoch rituals in seconds (default: 30)
# EPOCH_INTERVAL=30

# Heartbeat timeout for external agents in seconds (default: 30)
# HEARTBEAT_TIMEOUT=30
